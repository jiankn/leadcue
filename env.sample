# LeadCue 环境变量样板
# 只保留当前项目上线必需或已经接入代码路径的变量。
# 使用时复制到对应服务环境中，并替换占位值。不要提交真实密钥。

# -----------------------------------------------------------------------------
# Web / API URL
# -----------------------------------------------------------------------------

# APP_URL
# Web 站点公开地址。
# 用途：OAuth 跳转、密码重置链接、Stripe 回跳、canonical/sitemap 基准地址。
# 本地：http://localhost:5173
# 生产：https://你的正式域名
APP_URL=http://localhost:5173

# VITE_API_URL
# 浏览器端调用 API 的地址。
# 用途：前端请求登录、leads、billing、analytics 等 API。
# 本地：http://localhost:8787
# 生产：https://你的 API 域名
VITE_API_URL=http://localhost:8787

# CORS_ORIGINS
# API 允许的前端来源，多个域名用英文逗号分隔。
# 用途：限制哪些 Web 域可以访问 API。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# AI / Gemini
# -----------------------------------------------------------------------------

# GOOGLE_API_KEY
# Google Gemini API Key。
# 用途：只在 leadcue-api 服务端调用 Gemini，不能放到前端 leadcue 项目。
GOOGLE_API_KEY=your_google_api_key_here

# AI_MODEL
# 默认 Gemini 模型。
AI_MODEL=gemini-3.1-pro-preview

# -----------------------------------------------------------------------------
# Auth / Google Login
# -----------------------------------------------------------------------------

# SESSION_SECRET
# 会话签名密钥。
# 用途：保护登录 session。生产必须使用 32 字符以上随机字符串。
SESSION_SECRET=replace-with-random-session-secret

# GOOGLE_CLIENT_ID
# Google OAuth Client ID。
# 用途：Google 登录。
GOOGLE_CLIENT_ID=replace-with-google-client-id

# GOOGLE_CLIENT_SECRET
# Google OAuth Client Secret。
# 用途：服务端完成 Google OAuth token exchange，不能暴露给前端。
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# GOOGLE_REDIRECT_URI
# Google OAuth 回调地址。
# 用途：Google 登录完成后回到 API。必须与 Google Cloud Console 完全一致。
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# -----------------------------------------------------------------------------
# Cloudflare D1
# -----------------------------------------------------------------------------

# D1_DATABASE_ID
# Cloudflare D1 数据库 ID。
# 用途：部署、迁移和生产数据库绑定。实际 binding 通常在 wrangler 配置中设为 DB。
D1_DATABASE_ID=replace-with-cloudflare-d1-database-id

# -----------------------------------------------------------------------------
# Email / Password Reset
# -----------------------------------------------------------------------------

# EMAIL_FROM
# 系统发件人。
# 用途：发送密码重置邮件。
EMAIL_FROM=LeadCue <support@leadcue.app>

# SUPPORT_EMAIL
# 客服邮箱。
# 用途：页面展示和异常兜底提示。
SUPPORT_EMAIL=support@leadcue.app

# RESEND_API_KEY
# Resend API Key。
# 用途：发送密码重置邮件。若最终选 Postmark/SendGrid，可替换为对应变量。
RESEND_API_KEY=replace-with-resend-api-key

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------

# STRIPE_SECRET_KEY
# Stripe 服务端密钥。
# 用途：创建 checkout session、客户门户、处理订阅状态。
STRIPE_SECRET_KEY=sk_test_replace

# STRIPE_WEBHOOK_SECRET
# Stripe Webhook Secret。
# 用途：校验 Stripe webhook 请求来源。
STRIPE_WEBHOOK_SECRET=whsec_replace

# STRIPE_PRICE_STARTER
# Starter 计划 Price ID。
# 用途：创建 Starter 订阅 checkout。
STRIPE_PRICE_STARTER=price_replace_starter

# STRIPE_PRICE_PRO
# Pro 计划 Price ID。
# 用途：创建 Pro 订阅 checkout。
STRIPE_PRICE_PRO=price_replace_pro

# STRIPE_PRICE_AGENCY
# Agency 计划 Price ID。
# 用途：创建 Agency 订阅 checkout。
STRIPE_PRICE_AGENCY=price_replace_agency

# -----------------------------------------------------------------------------
# SEO
# -----------------------------------------------------------------------------

# VITE_SITE_URL
# Web 端 SEO 站点根地址。
# 用途：canonical、hreflang、Open Graph、Twitter Card、结构化数据。
# 本地可以留空或填 http://localhost:5173，生产应与正式域名一致。
VITE_SITE_URL=http://localhost:5173

# VITE_GOOGLE_SITE_VERIFICATION
# Google Search Console 验证 token。
# 用途：在 head 中注入 google-site-verification meta。
VITE_GOOGLE_SITE_VERIFICATION=

# VITE_BING_SITE_VERIFICATION
# Bing Webmaster Tools 验证 token。
# 用途：在 head 中注入 msvalidate.01 meta。
VITE_BING_SITE_VERIFICATION=
