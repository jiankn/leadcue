{
  "name": "leadcue",
  "version": "0.1.0",
  "private": true,
  "description": "LeadCue monorepo for the website-first outbound research workspace MVP.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @leadcue/web run dev",
    "dev:api": "npm --workspace @leadcue/api run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run typecheck",
    "preview:web": "npm --workspace @leadcue/web run preview",
    "visual:check": "node scripts/capture-visuals.mjs",
    "visual:audit:locales": "node scripts/capture-public-locale-audit.mjs",
    "audit:locales:body": "node scripts/audit-public-body-locales.mjs",
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "audit:seo": "node scripts/audit-seo-readiness.mjs",
    "peek": "node scripts/peek-file.mjs",
    "test": "npm run test:unit",
    "test:all": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api --fileParallelism=false --sequence.concurrent=false",
    "test:ci": "npm run typecheck && npm run test:unit",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
