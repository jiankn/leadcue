{
  "name": "leadcue",
  "version": "0.1.0",
  "private": true,
  "description": "LeadCue monorepo for the AI website prospecting assistant MVP.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @leadcue/web run dev",
    "dev:api": "npm --workspace @leadcue/api run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run typecheck",
    "preview:web": "npm --workspace @leadcue/web run preview",
    "visual:check": "node scripts/capture-visuals.mjs",
    "peek": "node scripts/peek-file.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
