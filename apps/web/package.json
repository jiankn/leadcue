{
  "name": "@leadcue/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "content:generate": "node ../../scripts/generate-public-locale-data.mjs && node ../../scripts/generate-seo-assets.mjs",
    "build": "node ../../scripts/generate-seo-assets.mjs && tsc -p tsconfig.json && vite build && node ../../scripts/prerender-public-pages.mjs && node ../../scripts/validate-public-pages.mjs dist && node ../../scripts/run-smoke-check.mjs dist",
    "qa:public": "node ../../scripts/validate-public-pages.mjs dist",
    "qa:smoke": "node ../../scripts/run-smoke-check.mjs dist",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@leadcue/shared": "0.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.4",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
